<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/turn_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/your_turn"
            android:textColor="@color/text"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/turn_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="回合 1"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:layout_marginLeft="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/enemy_team"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        android:weightSum="4">

        <com.example.herokill.ui.HeroView
            android:id="@+id/enemy1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"/>

        <com.example.herokill.ui.HeroView
            android:id="@+id/enemy2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"/>

        <com.example.herokill.ui.HeroView
            android:id="@+id/enemy3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"/>

        <com.example.herokill.ui.HeroView
            android:id="@+id/enemy4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/log_scroll"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/surface"
        android:padding="8dp">

        <TextView
            android:id="@+id/game_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/selected_card_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择一张牌使用"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/player_hand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/player_team"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        android:weightSum="4">

        <com.example.herokill.ui.HeroView
            android:id="@+id/player1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"/>

        <com.example.herokill.ui.HeroView
            android:id="@+id/player2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"/>

        <com.example.herokill.ui.HeroView
            android:id="@+id/player3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"/>

        <com.example.herokill.ui.HeroView
            android:id="@+id/player4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_draw"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/draw_card"
            android:textColor="@color/text"
            android:background="@color/accent"
            android:padding="12dp 24dp"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btn_end_turn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/end_turn"
            android:textColor="@color/text"
            android:background="@color/secondary"
            android:padding="12dp 24dp"
            android:textSize="16sp"
            android:layout_marginLeft="16dp"/>

        <Button
            android:id="@+id/btn_restart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重新开始"
            android:textColor="@color/text"
            android:background="@color/primary_variant"
            android:padding="12dp 24dp"
            android:textSize="16sp"
            android:layout_marginLeft="16dp"/>
    </LinearLayout>

</LinearLayout>